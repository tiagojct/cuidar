<div class="login-container">
  <h1 class="login-brand">CUIDAR</h1>
  <p class="login-tagline">Apoio a cuidadores de doentes paliativos</p>

  <form action="/login" method="post" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <label for="email">
      Email
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        autofocus
        placeholder="o-seu@email.pt"
      >
    </label>

    <label for="password">
      Palavra-passe
      <input
        type="password"
        id="password"
        name="password"
        required
        autocomplete="current-password"
      >
    </label>

    <button type="submit" class="login-btn">Entrar</button>
  </form>
</div>
