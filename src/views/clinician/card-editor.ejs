<div class="page-header">
  <h2><%= title %></h2>
  <a href="/clinico/fichas" class="outline secondary">← Voltar</a>
</div>

<form method="post" action="<%= action %>">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <!-- Title + Category + Tags row -->
  <div class="form-grid-3">
    <label style="grid-column: 1 / 3;">
      Título *
      <input type="text" name="title" required maxlength="200"
        value="<%= card ? (card.title || '') : '' %>"
        placeholder="Ex: Gestão da dor em casa">
    </label>
    <label>
      Categoria *
      <select name="category_id" required>
        <option value="">Seleccionar…</option>
        <% categories.forEach(cat => { %>
        <option value="<%= cat.id %>"
          <%= card && Number(card.category_id) === cat.id ? 'selected' : '' %>>
          <%= cat.name %>
        </option>
        <% }) %>
      </select>
    </label>
  </div>

  <label>
    Tags
    <input type="text" name="tags"
      value="<%= card ? (card.tags || '') : '' %>"
      placeholder="Ex: dor, oncologia, domicílio (separadas por vírgula)">
    <small class="help-hint">Palavras-chave usadas na pesquisa pelos cuidadores. Separe com vírgulas.</small>
  </label>

  <!-- Applicable conditions -->
  <fieldset>
    <legend>Condições aplicáveis</legend>
    <div class="conditions-grid">
      <% diagnoses.forEach(d => { %>
      <label class="condition-check">
        <input type="checkbox" name="applicable_conditions" value="<%= d.slug %>"
          <%= selectedConditions.includes(d.slug) ? 'checked' : '' %>>
        <%= d.name %>
      </label>
      <% }) %>
    </div>
    <small class="help-hint">A ficha só aparece aos cuidadores cujo doente tenha uma das condições seleccionadas. Seleccione "Geral" para aparecer sempre.</small>
  </fieldset>

  <!-- Markdown editor + preview -->
  <div class="editor-tabs" id="editor-tabs" role="tablist" aria-label="Alternar entre edição e pré-visualização">
    <button type="button" class="editor-tab active" data-pane="editor-col"
      role="tab" aria-selected="true"  aria-controls="editor-col">Editar</button>
    <button type="button" class="editor-tab"        data-pane="preview-col"
      role="tab" aria-selected="false" aria-controls="preview-col">Pré-visualizar</button>
  </div>

  <div class="editor-grid">
    <div id="editor-col" class="editor-pane">
      <label for="body-markdown">Conteúdo (Markdown) *</label>
      <textarea id="body-markdown" name="body_markdown" required
        rows="20" placeholder="## Título da secção

**Negrito** e _itálico_.

- Ponto 1
- Ponto 2

### Quando contactar a equipa

Contacte a equipa se..."><%= card ? (card.body_markdown || '') : '' %></textarea>
    </div>
    <div id="preview-col" class="preview-col">
      <p class="editor-label">Pré-visualização</p>
      <div id="preview-content" class="preview-pane-content prose">
        <em class="text-muted">Escreva no editor para ver a pré-visualização.</em>
      </div>
    </div>
  </div>

  <% if (card && card.id && allCards.length > 0) { %>
  <fieldset>
    <legend>Fichas relacionadas</legend>
    <div class="conditions-grid">
      <% allCards.forEach(c => { %>
      <label class="condition-check">
        <input type="checkbox" name="related_cards" value="<%= c.id %>"
          <%= relatedIds.includes(c.id) ? 'checked' : '' %>>
        <%= c.title %>
      </label>
      <% }) %>
    </div>
    <small>Seleccione fichas que devem aparecer como sugestões relacionadas ao ler esta ficha.</small>
  </fieldset>
  <% } %>

  <div class="form-actions">
    <button type="submit"><%= submitLabel %></button>
    <a href="/clinico/fichas" class="outline secondary">Cancelar</a>
  </div>
</form>

<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>
<script>
(function() {
  const textarea = document.getElementById('body-markdown');
  const preview  = document.getElementById('preview-content');
  const tabs     = document.querySelectorAll('.editor-tab');
  const panes    = { 'editor-col': document.getElementById('editor-col'), 'preview-col': document.getElementById('preview-col') };

  function updatePreview() {
    if (typeof marked !== 'undefined') {
      preview.innerHTML = marked.parse(textarea.value || '');
    }
  }

  textarea.addEventListener('input', updatePreview);
  updatePreview();

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      const target = tab.dataset.pane;
      Object.entries(panes).forEach(function([id, el]) {
        if (id === target) {
          el.classList.remove('hidden-mobile');
          el.classList.add('visible-mobile');
        } else {
          el.classList.add('hidden-mobile');
          el.classList.remove('visible-mobile');
        }
      });
      if (target === 'preview-col') updatePreview();
    });
  });
})();
</script>
