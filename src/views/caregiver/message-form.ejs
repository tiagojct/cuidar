<div class="info-card-nav" style="margin-bottom:1rem">
  <a href="/cuidador/doentes/<%= patient.id %>" class="outline secondary btn-sm">← Voltar</a>
  <span class="text-muted"><small><%= patient.identifier %></small></span>
</div>

<h2>Enviar mensagem à equipa clínica</h2>
<p class="text-muted">Use este formulário para colocar uma dúvida, reportar uma preocupação ou pedir orientação à equipa. Não substitui o contacto directo em situações urgentes.</p>

<form method="post" action="/cuidador/doentes/<%= patient.id %>/mensagem" style="max-width:560px">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <label>
    Mensagem *
    <textarea name="message" rows="5" required maxlength="2000"
      placeholder="Escreva aqui a sua dúvida ou preocupação…"></textarea>
    <small class="help-hint">Máximo 2000 caracteres.</small>
  </label>

  <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer">
    <input type="checkbox" name="is_urgent" value="1" role="switch">
    Situação urgente — necessito de resposta rápida
  </label>

  <div class="form-actions" style="margin-top:1.5rem">
    <button type="submit">Enviar mensagem</button>
    <a href="/cuidador/doentes/<%= patient.id %>" class="outline secondary">Cancelar</a>
  </div>
</form>
